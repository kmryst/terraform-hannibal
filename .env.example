# ローカル開発用の環境変数テンプレート
# このファイルをコピーして .env を作成してください: cp .env.example .env
# .env は git 管理外です（.gitignore に記載）
# 本番の設定値は ECS タスク定義（Terraform）と Secrets Manager から渡されます

PORT=3000
HOST=0.0.0.0
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# DB 接続情報（ローカル開発用）
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSLMODE=disable
DB_SSLROOTCERT=
